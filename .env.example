# ===========================================
# Thiago Seixas — variáveis de ambiente
# Copie este arquivo para .env.local e preencha.
# No Netlify, cadastre os valores em Site configuration > Environment variables.
# ===========================================

NEXT_PUBLIC_SITE_URL=https://thiagoseixas.adv.br

# ========== SANITY ==========
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_READ_TOKEN=
SANITY_WRITE_TOKEN=

# ========== GA4 / GTM ==========
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ========== CONTATO ==========
# Webhook do formulário — Formspree, endpoint próprio ou função serverless.
# Sem endpoint, o formulário usa fallback por e-mail e a conversão por /obrigado não dispara.
NEXT_PUBLIC_FORM_ENDPOINT=
NEXT_PUBLIC_WHATSAPP=5519999302552
NEXT_PUBLIC_EMAIL=contato@thiagoseixas.adv.br
