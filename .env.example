# ===========================================
# Thiago Seixas — variáveis de ambiente
# Copie este arquivo para .env.local e preencha
# ===========================================

# URL canônica do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://thiagoseixas.adv.br

# ========== SANITY ==========
# Obtenha em sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Token de leitura (opcional — só se dataset for privado)
SANITY_API_READ_TOKEN=

# Token de ESCRITA — necessário apenas para rodar "npm run seed"
# Crie em sanity.io/manage → API → Tokens → permissão "Editor"
SANITY_WRITE_TOKEN=

# ========== GA4 / GTM ==========
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# ========== CONTATO ==========
# Webhook do formulário — ex: Formspree, Netlify Forms, ou endpoint próprio
NEXT_PUBLIC_FORM_ENDPOINT=

# WhatsApp oficial (apenas dígitos com DDI)
NEXT_PUBLIC_WHATSAPP=5519999302552

# E-mail oficial
NEXT_PUBLIC_EMAIL=contato@thiagoseixas.adv.br
